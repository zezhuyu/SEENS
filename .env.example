# ─── AI Agents ────────────────────────────────────────────────────────────────
# Uses CLI subprocesses — no API keys needed for AI!
#
# Claude Code: uses your Claude Code subscription (Max/Pro)
#   Requires: claude CLI logged in (`claude --version` to check)
#
# Codex: uses your Codex CLI login (ChatGPT Plus or API key via `codex login`)
#   Requires: codex CLI logged in (`codex --version` to check)
#
# Active agent: "claude" or "codex" (switch at runtime via POST /api/settings/agent)
AI_AGENT=claude

# Optional: override the Codex CLI model.
# Default app behavior uses gpt-5.4-mini to save tokens.
# CODEX_MODEL=gpt-5.4-mini

# Optional: override CLI binary paths if not on PATH
# CLAUDE_BIN=/opt/homebrew/bin/claude
# CODEX_BIN=/opt/homebrew/bin/codex
#
# Optional: extra PATH entries for Finder-launched macOS app builds.
# The Electron app also reads your login-shell PATH; use this only for paths
# that are still missing. Separate entries with ":".
# SEENS_EXTRA_PATHS=/etc/profiles/per-user/your-user/bin:/run/current-system/sw/bin

# ─── Music Services ───────────────────────────────────────────────────────────
# Spotify (PKCE — no client secret needed)
SPOTIFY_CLIENT_ID=

# YouTube / Google OAuth2
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Apple Music (Apple Developer account required)
APPLE_KEY_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY_PATH=


# ─── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft Calendar ─────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=7477
NODE_ENV=development

# ─── TTS ──────────────────────────────────────────────────────────────────────
# Run: say -v ? | grep en_ to list English voices
TTS_VOICE=Samantha
