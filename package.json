{
  "name": "seens-radio",
  "version": "1.0.0",
  "description": "Personal AI radio station for Mac — Claude/Codex DJ + Spotify/Claude Music/YouTube",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.js",
    "dev": "npm run rebuild:node && nodemon server.js",
    "setup": "node scripts/setup.js",
    "sync": "node scripts/sync-music.js",
    "install-agent": "node scripts/install-agent.js",
    "install-skill": "node scripts/install-skill-global.js",
    "electron": "electron electron/main.cjs",
    "electron:dev": "NODE_ENV=development electron electron/main.cjs",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "npx electron-rebuild -v 33.4.11 --only better-sqlite3,fsevents,iconv-corefoundation",
    "dist": "SKIP_MAC_NOTARIZE=1 CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --arm64 -c.mac.forceCodeSigning=false -c.mac.identity=null && node scripts/install-sqlite3-prebuilt.cjs \"dist/mac-arm64/Seens Radio.app/Contents/Resources/app.asar.unpacked/node_modules/better-sqlite3/build/Release/better_sqlite3.node\" && node scripts/post-sign-macos-local.cjs",
    "update-app": "node scripts/update-app-asar.cjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "bonjour-service": "^1.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-ws": "^5.0.2",
    "googleapis": "^144.0.0",
    "node-schedule": "^2.1.1",
    "spotify-web-api-node": "^5.0.2",
    "ws": "^8.18.0",
    "yt-search": "^2.13.1"
  },
  "optionalDependencies": {
    "airtunes2": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.1.4"
  },
  "build": {
    "appId": "com.seens.radio",
    "productName": "Seens Radio",
    "mac": {
      "category": "public.app-category.music",
      "icon": "electron/icon.icns",
      "forceCodeSigning": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSLocationWhenInUseUsageDescription": "Seens Radio uses your location to show local weather and tailor the DJ context to your city.",
        "NSLocationUsageDescription": "Seens Radio uses your location to show local weather and tailor the DJ context to your city.",
        "NSMicrophoneUsageDescription": "Seens Radio can use your microphone for voice-driven radio controls and audio features."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "files": [
      "electron/**/*",
      "server.js",
      "routes/**/*",
      "src/**/*",
      "music/**/*",
      "auth/**/*",
      "public/**/*",
      "scripts/**/*",
      "prompts/**/*",
      "USER/**/*",
      "node_modules/**/*",
      ".env",
      "package.json"
    ],
    "npmRebuild": false,
    "extraFiles": [],
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node"
    ]
  }
}
