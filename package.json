{
  "name": "seens-radio",
  "version": "1.0.0",
  "description": "Personal AI radio station for Mac — Claude/Codex DJ + Spotify/Apple Music/YouTube",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup": "node scripts/setup.js",
    "sync": "node scripts/sync-music.js",
    "install-agent": "node scripts/install-agent.js",
    "electron": "electron electron/main.cjs",
    "electron:dev": "NODE_ENV=development electron electron/main.cjs",
    "dist": "electron-builder --mac --arm64"
  },
  "dependencies": {
    "airtunes2": "^2.0.0",
    "better-sqlite3": "^12.9.0",
    "bonjour-service": "^1.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-ws": "^5.0.2",
    "googleapis": "^144.0.0",
    "node-schedule": "^2.1.1",
    "spotify-web-api-node": "^5.0.2",
    "ws": "^8.18.0",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.1.4"
  },
  "build": {
    "appId": "com.seens.radio",
    "productName": "Seens Radio",
    "mac": {
      "category": "public.app-category.music",
      "icon": "electron/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "files": [
      "electron/**/*",
      "server.js",
      "routes/**/*",
      "src/**/*",
      "music/**/*",
      "auth/**/*",
      "public/**/*",
      "scripts/**/*",
      "node_modules/**/*",
      ".env",
      "package.json"
    ],
    "extraFiles": [],
    "asar": false
  }
}
